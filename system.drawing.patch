+	// Reads all remaining bytes from a stream into a trimmed byte array.
+	private static byte[] ReadStreamFully (Stream stream)
+	{
+		// Fast path: MemoryStream — grab its buffer directly if possible.
+		MemoryStream ms = stream as MemoryStream;
+		if (ms != null) {
+			return ms.ToArray ();
+		}
+
+		byte[] buffer = new byte[4096];
+		int index = 0;
+		int count;
+		do {
+			if (buffer.Length < index + 4096) {
+				byte[] newBuffer = new byte[buffer.Length * 2];
+				Array.Copy (buffer, newBuffer, index);
+				buffer = newBuffer;
+			}
+			count = stream.Read (buffer, index, 4096);
+			index += count;
+		}
+		while (count != 0);
+
+		byte[] result = new byte[index];
+		Array.Copy (buffer, result, index);
+		return result;
+	}
